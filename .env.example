# ─── Database (Neon PostgreSQL) ───────────────────────────────────────────────
DATABASE_URL="postgresql://username:password@host/dbname?sslmode=require&pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://username:password@host/dbname?sslmode=require"

# ─── NextAuth ─────────────────────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-nextauth-secret-min-32-chars"

# ─── Google OAuth (for Google sign-in) ───────────────────────────────────────
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ─── Resend (Transactional Email) ─────────────────────────────────────────────
RESEND_API_KEY="re_your_resend_api_key"
RESEND_FROM_EMAIL="ScopeAI <noreply@yourdomain.com>"

# ─── Security ─────────────────────────────────────────────────────────────────
TOKEN_ENCRYPTION_KEY="your-32-byte-base64-key"

# ─── Upstash Redis (Rate Limiting & Caching) ──────────────────────────────────
UPSTASH_REDIS_REST_URL="https://your-redis.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-token"

# ─── Cloudflare R2 (File Storage) ────────────────────────────────────────────
R2_ACCOUNT_ID="your-cloudflare-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
R2_BUCKET_NAME="scopeai-scope-documents"
R2_PUBLIC_URL="https://your-r2-url"

# ─── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY="sk-your-openai-api-key"

# ─── Sentry ───────────────────────────────────────────────────────────────────
SENTRY_DSN="https://your-sentry-dsn"
NEXT_PUBLIC_SENTRY_DSN="https://your-sentry-dsn"

# ─── Trigger.dev ─────────────────────────────────────────────────────────────
TRIGGER_SECRET_KEY="your-trigger-secret-key"
NEXT_PUBLIC_TRIGGER_PUBLIC_API_KEY="your-trigger-public-key"

# ─── Paddle (Billing) ─────────────────────────────────────────────────────────
PADDLE_API_KEY="your-paddle-api-key"
PADDLE_WEBHOOK_SECRET="your-paddle-webhook-secret"
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN="your-paddle-client-token"

# ─── Slack Integration ────────────────────────────────────────────────────────
SLACK_CLIENT_ID="your-slack-client-id"
SLACK_CLIENT_SECRET="your-slack-client-secret"
SLACK_SIGNING_SECRET="your-slack-signing-secret"

# ─── Gmail Integration ────────────────────────────────────────────────────────
GMAIL_CLIENT_ID="your-gmail-client-id"
GMAIL_CLIENT_SECRET="your-gmail-client-secret"
GMAIL_PUBSUB_TOPIC="projects/your-project/topics/gmail-push"
GMAIL_PUBSUB_SUBSCRIPTION="projects/your-project/subscriptions/gmail-push-sub"

# ─── Outlook Integration ─────────────────────────────────────────────────────
MICROSOFT_CLIENT_ID="your-azure-app-client-id"
MICROSOFT_CLIENT_SECRET="your-azure-app-client-secret"
MICROSOFT_TENANT_ID="common"

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
